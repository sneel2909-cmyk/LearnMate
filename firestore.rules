rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
          && data.email is string && data.email.size() <= 256
          && data.role in ['student', 'parent', 'educator']
          && (data.tokens == null || data.tokens is number)
          && (data.firstName is string && data.firstName.size() <= 100)
          && (data.lastName is string && data.lastName.size() <= 100);
      }

      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        // Action: Generic Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['firstName', 'lastName', 'birthDate', 'grade', 'onboardingStep', 'isVerified', 'learningProfile', 'tokens', 'updatedAt']) && incoming().updatedAt == request.time && incoming().createdAt == existing().createdAt)
      );

      match /assessmentAnswers/{answerId} {
        allow read, write: if isOwner(userId) && isValidId(answerId);
      }
    }
  }
}
